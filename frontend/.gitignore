# ============================================================
# TeamUp Frontend — .gitignore
# React + Vite + Tailwind CSS
# ============================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Build output ───────────────────────────────────────────────
dist/
dist-ssr/
.radar/
out/
.rollup.cache/

# ── Vite / Rollup ─────────────────────────────────────────────
.vite/
.vitest/
*.local

# ── Testing ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Environment variables ─────────────────────────────────────
# ⚠️  NEVER commit .env files containing real API keys!
# Create a .env.example file with dummy values instead.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env

# ── Logs ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Editor directories and files ──────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.code-workspace

.DS_Store
Thumbs.db
*.iml
*.ipr
*.iws

# ── Cache ─────────────────────────────────────────────────────
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/

# ── Misc ───────────────────────────────────────────────────────
*.swp
*.swo
*~
dist_tsbuildinfo.json
*.tsbuildinfo
*.tsbuildinfo
.npm
.eslintrc.precompute
