# ============================================================
# TeamUp — Example environment variables
# Copy this file to .env and fill in real values.
# The .env file is already in .gitignore — it will NEVER be pushed.
# ============================================================

# ── Spring Boot Application ────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# ── Database ───────────────────────────────────────────────────
# PostgreSQL (recommended for production)
DB_URL=jdbc:postgresql://localhost:5432/teamup
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# MySQL (alternative)
# DB_URL=jdbc:mysql://localhost:3306/teamup
# DB_USERNAME=your_db_user
# DB_PASSWORD=your_db_password

# ── JWT / Auth ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_at_least_32_chars
JWT_EXPIRATION_MS=86400000

# ── CORS ───────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── File Storage (for submissions) ─────────────────────────────
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ── Email (optional — for notifications) ──────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your_app_password

# ── Frontend API URL ──────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
