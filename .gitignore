# ============================================================
# TeamUp — Root .gitignore
# Spring Boot backend (Java) + root-level config
# ============================================================

# ── Maven (Java) ───────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar

# Build output (IntelliJ IDEA)
out/
build/
*.class

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# ── Gradle ────────────────────────────────────────────────────
.gradle/
*.log

# ── IntelliJ IDEA ─────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr
*.ids
*.idb
.idea_modules/

# File-based IDEs (VS Code, etc.)
.vscode/
*.code-workspace

# ── Eclipse ───────────────────────────────────────────────────
.settings/
.classpath
.project
.factorypath

# ── NetBeans ──────────────────────────────────────────────────
nbproject/private/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ── OS Generated ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
*.log.*

# ── Spring Boot ───────────────────────────────────────────────
spring-boot-*.log
spring-boot-devtools.properties

# ── Application properties & secrets ──────────────────────────
# ⚠️  NEVER commit real credentials or secrets!
# Copy this to application.properties and fill in real values.
# application-local.properties   ← local overrides (IGNORED)
# application-secrets.properties ← real DB/API keys (IGNORED)
src/main/resources/application-local.properties
src/main/resources/application-secrets.properties
src/main/resources/application-local.yml
src/main/resources/application-secrets.yml

# ── Environment / Secrets ──────────────────────────────────────
.env
.env.local
.env.*.local
*.env
secrets/
credentials/
config/secrets/
private-key.pem
*.pem
*.key

# ── Docker ────────────────────────────────────────────────────
docker-compose.override.yml
docker-compose.*.yml
*.dockerignore

# ── CI/CD (keep pipeline config, ignore secrets) ──────────────
# .github/workflows/         ← KEEP this directory
# .gitlab-ci.yml             ← KEEP this file
deploy/
deployment/
*.tfstate
*.tfstate.backup

# ── Misc ──────────────────────────────────────────────────────
*.swp
*.swo
*~
*.orig
*.rej
*.bak
*.tmp
*.temp
*.cache
*.tmp
*.pid
*.seed
*.pid.lock

# Lombok generated files (safe to ignore in some setups)
lombok.config.delombok/

# Coverage reports
jacoco.exec
*.exec
coverage/
*.lcov
